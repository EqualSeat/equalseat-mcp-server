{
  "name": "@equalseat/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the equalseat.ai knowledge base platform",
  "bin": {
    "equalseat-mcp": "./build/cli.cjs"
  },
  "type": "module",
  "main": "./build/cli.cjs",
  "files": [
    "build"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "mcp",
    "equalseat",
    "knowledge-base",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EqualSeat/equalseat-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
